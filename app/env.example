VITE_MAPBOX_TOKEN=
VITE_STRIPE_PUBLISHABLE_KEY=

# Backend shared key for `/api/v1/auth/**` (X-API-Key); match server `api_key` / local dev value
VITE_API_KEY=

# Host/domain (central config – single source of truth)
# VITE_ENVIRONMENT=production
# VITE_MAIN_DOMAIN=usemaison.io
# VITE_DEV_DOMAIN=localhost

# Dev API proxy (local dev only; set for Vite dev server to proxy /api)
VITE_API_PROXY=http://localhost:8000